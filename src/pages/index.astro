---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import emBrand from '../assets/em/brand.jpeg';
import emCover from '../assets/em/cover.jpeg';
import emPromo from '../assets/em/promo.jpeg';
import emScooter from '../assets/em/scooter.jpeg';
import hcEvent from '../assets/hc/event-coverage.jpeg';
import hcOnCamera from '../assets/hc/on-camera.jpeg';
import hcTrend from '../assets/hc/trend-story.jpeg';
import lvBody from '../assets/lv/body-campaign.webp';
import lvLaser from '../assets/lv/laser-campaign.webp';
import lvMyth from '../assets/lv/myth-reality.webp';
import lvSkin from '../assets/lv/skin-conscious.webp';
import anaPhoto from '../assets/profile/ana.png';

const projects = [
	{
		tag: 'Contenido · Identidad visual',
		title: 'LV Estética Avanzada',
		blurb: 'Publicidad, diseño de artes, estrategia editorial y gestión diaria de redes para una estética no invasiva y consciente.',
		chips: ['+412% visualizaciones', '13,6 mil / 30 días', '+1.384% alcance'],
		image: lvSkin,
		alt: 'Arte de cuidado facial para LV Estética Avanzada',
		social: { label: 'Instagram', href: 'https://www.instagram.com/lv_estetica_avanzada_/' },
	},
	{
		tag: 'TikTok · Frente a cámara',
		title: 'Hotel Carrión',
		blurb: 'Talento frente a cámara, grabación en instalaciones y exteriores, y edición dinámica para la campaña de TikTok del hotel.',
		chips: ['8 TikToks', 'Grabación', 'Edición'],
		image: hcOnCamera,
		alt: 'Ana Paulina presentando contenido para Hotel Carrión',
		social: { label: 'TikTok', href: 'https://www.tiktok.com/@hotelcarrionloja' },
	},
	{
		tag: 'Foto y video · Comunicación',
		title: 'Emobility',
		blurb: 'Producción y edición de fotografías y videos para comunicar productos de movilidad eléctrica de forma clara y cercana.',
		chips: ['240K reproducciones', 'Foto + video'],
		image: emCover,
		alt: 'Contenido de promoción de movilidad eléctrica para Emobility',
		social: { label: 'TikTok', href: 'https://www.tiktok.com/@emobilityloja' },
	},
	{
		tag: 'Producción · Paid media',
		title: 'FORED',
		blurb: 'Producción de contenido y optimización de pauta digital: un resultado comparable a una campaña de $90 con una inversión de ~$12.',
		chips: ['$12 ≈ $90', 'Proyecto de 1 mes'],
		big: '$12',
	},
];

const stripRowA = [lvSkin, hcOnCamera, emScooter, lvLaser, hcEvent];
const stripRowB = [emPromo, lvMyth, hcTrend, emBrand, lvBody];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<meta name="theme-color" content="#140d0c" />
	</head>
	<body>
		<nav class="site">
			<div class="wrap">
				<a class="brand" href="#top">Ana Paulina<span>.</span></a>
				<div class="nav-links">
					<a href="#trabajo">Trabajo</a>
					<a href="#perfil">Perfil</a>
					<a href="#servicios">Servicios</a>
					<a class="nav-cta" href="#contacto">Hablemos</a>
				</div>
			</div>
		</nav>

		<main id="top">
			<section class="hero">
				<div class="wrap">
					<span class="eyebrow">Creadora de contenido · Loja, Ecuador</span>
					<h1>Contenido que <em>conecta</em> marcas con personas.</h1>
					<p class="hero-lead">
						Soy Ana Paulina Sarmiento. Planifico, grabo, edito y publico contenido audiovisual
						y gestiono redes sociales para que las marcas se vean claras, humanas y difíciles de ignorar.
					</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href="#trabajo">Ver trabajo</a>
						<a class="btn btn-ghost" href="#contacto">Trabajemos juntos</a>
					</div>
					<p class="hero-clients">Marcas — LV Estética · Hotel Carrión · Emobility · FORED</p>
				</div>
			</section>

			<div class="strip" aria-hidden="true">
				<div class="strip-row strip-row-a">
					<div class="strip-track">
						{[...stripRowA, ...stripRowA, ...stripRowA, ...stripRowA].map((img) => (
							<Image src={img} alt="" widths={[220, 440]} sizes="220px" quality={82} loading="lazy" />
						))}
					</div>
				</div>
				<div class="strip-row strip-row-b">
					<div class="strip-track">
						{[...stripRowB, ...stripRowB, ...stripRowB, ...stripRowB].map((img) => (
							<Image src={img} alt="" widths={[220, 440]} sizes="220px" quality={82} loading="lazy" />
						))}
					</div>
				</div>
			</div>

			<section id="trabajo">
				<div class="wrap">
					<div class="sec-head reveal">
						<span class="eyebrow">Selección de trabajo</span>
						<h2>Proyectos reales, resultados reales.</h2>
						<p>Casos donde dirigí o produje el contenido y acompañé la comunicación de cada marca.</p>
					</div>

					<div class="work-grid">
						{projects.map((project) => (
							<article class="card reveal">
								<div class={`card-media ${project.image ? '' : 'no-img'}`}>
									{project.image ? (
										<Image src={project.image} alt={project.alt} widths={[400, 700]} sizes="(max-width: 720px) 100vw, 45vw" quality={88} loading="lazy" />
									) : (
										<span class="big">{project.big}</span>
									)}
								</div>
								<div class="card-body">
									<span class="card-tag">{project.tag}</span>
									<h3>{project.title}</h3>
									<p>{project.blurb}</p>
									<div class="chips">
										{project.chips.map((chip) => <span class="chip">{chip}</span>)}
									</div>
									{project.social && (
										<a class="card-link" href={project.social.href} target="_blank" rel="noopener noreferrer">
											{project.social.label}
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9"></path></svg>
										</a>
									)}
								</div>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="stats">
				<div class="wrap">
					<div class="stat reveal"><div class="n">240K</div><div class="l">reproducciones en una pieza para Emobility</div></div>
					<div class="stat reveal"><div class="n">+412%</div><div class="l">crecimiento de visualizaciones en un mes con LV</div></div>
					<div class="stat reveal"><div class="n">$12 ≈ $90</div><div class="l">rendimiento de pauta optimizada en FORED</div></div>
				</div>
			</section>

			<section id="perfil" class="about">
				<div class="wrap">
					<div class="about-photo reveal">
						<Image src={anaPhoto} alt="Ana Paulina Sarmiento" widths={[320, 480]} sizes="(max-width: 720px) 60vw, 320px" quality={90} />
					</div>
					<div class="reveal">
						<span class="eyebrow">Perfil</span>
						<h2>Convierto ideas en contenido que la gente recuerda.</h2>
						<p>
							Soy Ana Paulina Sarmiento. Trabajo de punta a punta: estrategia, calendario, grabación,
							diseño de piezas, copywriting y edición. Cada publicación se piensa para que la marca
							se vea coherente y con personalidad propia.
						</p>
						<p>
							Cuento con equipo audiovisual propio (DJI Mic 2, DJI Osmo Mobile, iluminación ajustable)
							y manejo CapCut, InShot, Canva, Premiere Pro y Photoshop.
						</p>
					</div>
				</div>
			</section>

			<section id="servicios">
				<div class="wrap">
					<div class="sec-head reveal">
						<span class="eyebrow">Lo que hago</span>
						<h2>Servicios</h2>
					</div>
					<div class="svc-grid reveal">
						<span class="svc">Dirección de contenido</span>
						<span class="svc">Producción audiovisual</span>
						<span class="svc">Identidad visual &amp; diseño</span>
						<span class="svc">Estrategia para redes</span>
						<span class="svc">Copywriting</span>
						<span class="svc">Edición de video</span>
					</div>
					<p class="tools reveal">CapCut · InShot · Canva · Premiere Pro · Photoshop</p>
				</div>
			</section>

			<section id="contacto" class="contact">
				<div class="wrap">
					<div class="reveal">
						<span class="eyebrow">¿Creamos algo juntas?</span>
						<h2>Cuéntame <em>tu idea.</em></h2>
						<div class="c-list">
							<a href="mailto:anitapauly91@gmail.com">anitapauly91@gmail.com</a>
							<a href="tel:+593994195423">+593 99 419 5423</a>
							<span>Loja, Ecuador</span>
						</div>
						<div class="c-social">
							<a href="https://www.instagram.com/anita_sarmiento1026" target="_blank" rel="noopener noreferrer">Instagram</a>
							<a href="https://www.behance.net/anitasarmiento" target="_blank" rel="noopener noreferrer">Behance</a>
						</div>
					</div>

					<form class="card-form reveal" action="https://formsubmit.co/anitapauly91@gmail.com" method="POST">
						<input type="hidden" name="_subject" value="Nuevo mensaje desde el portafolio" />
						<input type="hidden" name="_template" value="table" />
						<input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
						<label class="field">
							<span>Nombre</span>
							<input type="text" name="name" required placeholder="Tu nombre" />
						</label>
						<label class="field">
							<span>Correo</span>
							<input type="email" name="email" required placeholder="tucorreo@ejemplo.com" />
						</label>
						<label class="field">
							<span>Mensaje</span>
							<textarea name="message" rows="4" required placeholder="Cuéntame sobre tu marca o proyecto"></textarea>
						</label>
						<button type="submit">Enviar mensaje</button>
					</form>
				</div>
			</section>
		</main>

		<footer>
			<div class="wrap">
				<span>© {new Date().getFullYear()} Ana Paulina Sarmiento</span>
				<span>Contenido · Estrategia · Diseño</span>
				<a href="#top">Volver arriba ↑</a>
			</div>
		</footer>

		<script>
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const items = document.querySelectorAll('.reveal');
			if (reduce) {
				items.forEach((el) => el.classList.add('in'));
			} else {
				const io = new IntersectionObserver(
					(entries) => entries.forEach((e) => {
						if (e.isIntersecting) {
							e.target.classList.add('in');
							io.unobserve(e.target);
						}
					}),
					{ threshold: 0.15 },
				);
				items.forEach((el) => io.observe(el));
			}
		</script>
	</body>
</html>
